# Database
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/openrag

# Security
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY
JWT_SECRET_KEY=REPLACE_WITH_STRONG_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Frontend and backend URLs
APP_BASE_URL=http://localhost:5173
BACKEND_URL=http://localhost:8081/mnemo

# Email (SendGrid)
SENDGRID_API_KEY=REPLACE_WITH_SENDGRID_KEY
SENDGRID_FROM_EMAIL=no-reply@example.com

# Google Drive OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8081/mnemo/connectors/gdrive/callback
